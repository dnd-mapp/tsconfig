{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": ["./base.json"],
    "compilerOptions": {
        "erasableSyntaxOnly": false,
        "experimentalDecorators": true,
        "lib": ["ES2024", "DOM"],
        "module": "preserve",
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "target": "es2024"
    }
}
